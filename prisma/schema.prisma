// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

// ==================== AUTH.JS MODELS ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  mainCurrency  String    @default("IDR") // User's preferred currency for reporting

  // Financial targets
  retirementTarget Float?
  monthlyBudget    Float?

  // Encryption metadata for field-level encryption
  encryptionSalt    String? @db.Text // Base64-encoded salt for key derivation
  encryptionVersion Int     @default(1) // For key rotation support

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js relations
  accounts AuthAccount[]
  sessions Session[]

  // Financial relations
  financialAccounts FinancialAccount[]
  transactions      Transaction[]
  transactionSplits TransactionSplit[]
  categories        Category[]
  investmentAssets  InvestmentAsset[]
  tradeHistory      TradeHistory[]
  recurringRules    RecurringRule[]
  subscriptions     Subscription[]
  budgets           Budget[]
  savingsGoals      SavingsGoal[]
  personalAssets    PersonalAsset[]
  personalAssetValuations PersonalAssetValuation[]
  depositoAccounts  DepositoAccount[]
  netWorthSnapshots NetWorthSnapshot[]
  debtPlans         DebtPlan[]
  debtPlanItems     DebtPlanItem[]
  pushSubscriptions PushSubscription[]
  notificationPreference NotificationPreference?
  notificationEvents NotificationEvent[]
}

model AuthAccount {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ==================== FINANCIAL MODELS ====================

enum AccountType {
  BANK
  CASH
  INVESTMENT
  DEPOSITO
  LOAN
  CREDIT_CARD
  LOAN_RECEIVABLE
}

enum DepositoInterestFrequency {
  DAILY
  MONTHLY
  YEARLY
}

enum DepositoTermMode {
  OPEN_ENDED
  FIXED_TERM
}

enum DepositoStatus {
  ACTIVE
  MATURED
  CLOSED
}

model FinancialAccount {
  id                   String      @id @default(cuid())
  nameEncrypted        String      @db.Text // Encrypted account name
  type                 AccountType
  currency             String      @default("IDR") // ISO currency code
  balance              Float       @default(0)
  descriptionEncrypted String?     @db.Text // Encrypted description
  isActive             Boolean     @default(true)

  // Encryption metadata
  lastEncryptedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromTransactions Transaction[] @relation("FromAccount")
  toTransactions   Transaction[] @relation("ToAccount")

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  investmentAssets InvestmentAsset[]
  tradeHistories   TradeHistory[]
  transactions     Transaction[]
  subscriptions    Subscription[]
  goalLinks        SavingsGoalAccount[]
  depositoAccount  DepositoAccount?
  debtPlanItems    DebtPlanItem[]

  @@index([userId])
}

model DepositoAccount {
  id                String                    @id @default(cuid())
  startDate         DateTime
  principalAmount   Float
  interestFrequency DepositoInterestFrequency
  interestRate      Float
  taxRate           Float?
  termMode          DepositoTermMode         @default(OPEN_ENDED)
  maturityDate      DateTime?
  nextInterestDate  DateTime?
  status            DepositoStatus           @default(ACTIVE)
  closedAt          DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String           @unique
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  openingTransactionId String?      @unique
  openingTransaction   Transaction? @relation("DepositoOpeningTransaction", fields: [openingTransactionId], references: [id], onDelete: SetNull)
  closingTransactionId String?      @unique
  closingTransaction   Transaction? @relation("DepositoClosingTransaction", fields: [closingTransactionId], references: [id], onDelete: SetNull)

  interestPostings DepositoInterestPosting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, nextInterestDate])
}

model DepositoInterestPosting {
  id            String   @id @default(cuid())
  postingDate   DateTime
  grossInterest Float
  taxAmount     Float    @default(0)
  netInterest   Float
  balanceBefore Float
  balanceAfter  Float

  depositoAccountId String
  depositoAccount   DepositoAccount @relation(fields: [depositoAccountId], references: [id], onDelete: Cascade)

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([depositoAccountId, postingDate])
  @@index([depositoAccountId, postingDate])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  LIABILITY_PAYMENT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

model Category {
  id       String          @id @default(cuid())
  name     String
  icon     String?
  color    String?
  type     TransactionType
  isSystem Boolean         @default(false) // Seed/default marker for starter categories

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  transactionSplits TransactionSplit[]
  budgetCategories BudgetCategory[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id                   String          @id @default(cuid())
  clientMutationId     String?
  amount               Float
  currency             String          @default("IDR") // Transaction currency
  exchangeRate         Float           @default(1) // Rate to convert to user's main currency
  type                 TransactionType
  description          String?
  descriptionEncrypted String?         @db.Text // Encrypted description
  location             String?         @db.Text
  latitude             Float?
  longitude            Float?
  googleMapsLink       String?         @db.Text
  date                 DateTime        @default(now())
  isRecurring          Boolean         @default(false)

  // Liability payment specific fields
  referenceNumber          String?       @unique
  referenceNumberEncrypted String?       @db.Text // Encrypted reference number
  isOverpayment            Boolean       @default(false)
  paymentStatus            PaymentStatus @default(COMPLETED)

  // Audit trail fields
  createdBy          String?
  createdByEncrypted String?  @db.Text // Encrypted createdBy
  processedAt        DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String
  account   FinancialAccount @relation("FromAccount", fields: [accountId], references: [id], onDelete: Cascade)

  toAccountId String?
  toAccount   FinancialAccount? @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  splits          TransactionSplit[]

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  financialAccountId String?

  // Reverse relation for audit
  liabilityPaymentAudit LiabilityPaymentAudit?
  depositoOpening      DepositoAccount?        @relation("DepositoOpeningTransaction")
  depositoClosing      DepositoAccount?        @relation("DepositoClosingTransaction")
  depositoInterestPosting DepositoInterestPosting?

  @@index([userId])
  @@unique([userId, clientMutationId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@index([date])
  @@index([userId, date])
  @@index([userId, accountId, date])
  @@index([userId, type, date])
  @@index([referenceNumber])
  @@index([financialAccountId], map: "Transaction_financialAccountId_fkey")
  @@index([recurringRuleId], map: "Transaction_recurringRuleId_fkey")
}

model TransactionSplit {
  id                   String      @id @default(cuid())
  amount               Float
  description          String?
  descriptionEncrypted String?     @db.Text
  sortOrder            Int         @default(0)

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([userId])
  @@index([categoryId])
  @@index([userId, transactionId])
}

// ==================== INVESTMENT MODELS ====================

model InvestmentAsset {
  id          String   @id @default(cuid())
  symbol      String // e.g., AAPL, BTC-USD
  name        String? // e.g., Apple Inc.
  quantity    Float
  avgBuyPrice Float // Cost basis per unit
  currency    String   @default("IDR") // Asset's trading currency
  unitType    UnitType @default(UNIT) // Unit of quantity

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Account linkage for tracking which investment account holds this asset
  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  tradeHistory TradeHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
  @@index([accountId])
}

enum TradeType {
  BUY
  SELL
}

enum UnitType {
  UNIT // Stocks, ETFs - 1 share = 1 unit
  TROY_OUNCE // Precious metals from Yahoo Finance
  GRAM // User preference for metals
}

model TradeHistory {
  id             String    @id @default(cuid())
  type           TradeType
  quantity       Float
  pricePerUnit   Float
  totalAmount    Float
  fees           Float     @default(0)
  date           DateTime  @default(now())
  notes          String?
  notesEncrypted String?   @db.Text // Encrypted trade notes
  unitType       UnitType  @default(UNIT)

  // Realized PnL (only for SELL trades)
  realizedPnL Float?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assetId String
  asset   InvestmentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Account linkage for audit trail - tracks which account was debited/credited
  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  // Audit trail fields for balance tracking
  balanceBefore Float? // Account balance before this transaction
  balanceAfter  Float? // Account balance after this transaction

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assetId])
  @@index([accountId])
  @@index([date])
}

// ==================== RECURRING TRANSACTIONS ====================

enum RecurringInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringRule {
  id            String            @id @default(cuid())
  name          String
  nameEncrypted String?           @db.Text // Encrypted name
  amount        Float
  currency      String            @default("IDR")
  type          TransactionType
  interval      RecurringInterval
  nextDueDate   DateTime
  endDate       DateTime?
  isActive      Boolean           @default(true)

  // Template data for creating transactions
  description          String?
  descriptionEncrypted String? @db.Text // Encrypted description
  categoryId           String?
  accountId            String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  subscription Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([nextDueDate])
}

enum SubscriptionBillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAUSED
  CANCELLED
  EXPIRED
}

model Subscription {
  id                       String                    @id @default(cuid())
  name                     String
  nameEncrypted            String?                   @db.Text
  provider                 String?
  providerEncrypted        String?                   @db.Text
  description              String?
  descriptionEncrypted     String?                   @db.Text
  amount                   Float
  currency                 String                    @default("IDR")
  billingCycle             SubscriptionBillingCycle
  nextBillingDate          DateTime
  startDate                DateTime?
  trialEndDate             DateTime?
  cancellationDate         DateTime?
  status                   SubscriptionStatus
  cancellationUrl          String?                   @db.Text
  cancellationUrlEncrypted String?                   @db.Text
  notes                    String?
  notesEncrypted           String?                   @db.Text

  categoryId      String?
  category        Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId       String?
  account         FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  recurringRuleId String?           @unique
  recurringRule   RecurringRule?    @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, nextBillingDate])
  @@index([userId, trialEndDate])
  @@index([accountId])
  @@index([categoryId])
}

// ==================== EXCHANGE RATES CACHE ====================

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  fetchedAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency])
  @@index([fetchedAt])
}

model GoldPriceSnapshot {
  id                        String    @id @default(cuid())
  provider                  String
  source                    String
  currency                  String    @default("IDR")
  customerBuyPrice          Float
  customerSellPrice         Float
  customerBuyChangePercent  Float?
  customerSellChangePercent Float?
  unitGram                  Float
  effectiveDate             DateTime
  sourceUpdatedAt           DateTime?
  fetchedAt                 DateTime  @default(now())

  @@index([provider, source, fetchedAt])
  @@index([provider, source, effectiveDate])
}

model NetWorthSnapshot {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodYear   Int
  periodMonth  Int
  snapshotDate DateTime

  currency String

  totalAssets      Decimal @default(0) @db.Decimal(20, 4)
  totalLiabilities Decimal @default(0) @db.Decimal(20, 4)
  netWorth         Decimal @default(0) @db.Decimal(20, 4)

  cashTotal              Decimal @default(0) @db.Decimal(20, 4)
  bankTotal              Decimal @default(0) @db.Decimal(20, 4)
  investmentCashTotal    Decimal @default(0) @db.Decimal(20, 4)
  investmentHoldingTotal Decimal @default(0) @db.Decimal(20, 4)
  investmentTotal        Decimal @default(0) @db.Decimal(20, 4)
  personalAssetTotal     Decimal @default(0) @db.Decimal(20, 4)
  receivableTotal        Decimal @default(0) @db.Decimal(20, 4)

  loanLiabilityTotal    Decimal @default(0) @db.Decimal(20, 4)
  creditCardTotal       Decimal @default(0) @db.Decimal(20, 4)
  liabilityOverpayTotal Decimal @default(0) @db.Decimal(20, 4)

  sourceBreakdownJson Json?
  exchangeRateJson    Json?
  calculationVersion  Int   @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, periodYear, periodMonth])
  @@index([userId, snapshotDate])
}

// ==================== DEBT PAYOFF PLANNER ====================

enum DebtPayoffStrategy {
  AVALANCHE
  SNOWBALL
  CUSTOM
}

model DebtPlan {
  id                 String             @id @default(cuid())
  name               String             @default("My debt payoff plan")
  strategy           DebtPayoffStrategy @default(AVALANCHE)
  extraMonthlyAmount Float              @default(0)
  currency           String             @default("IDR")
  isActive           Boolean            @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items DebtPlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
}

model DebtPlanItem {
  id                 String @id @default(cuid())
  annualInterestRate Float // APR as percent, e.g. 18.5 means 18.5% per year
  minimumPayment     Float
  priorityOverride   Int? // Lower value = higher priority when strategy is CUSTOM
  paymentDayOfMonth  Int    @default(1)

  debtPlanId String
  debtPlan   DebtPlan @relation(fields: [debtPlanId], references: [id], onDelete: Cascade)

  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([debtPlanId, accountId])
  @@index([debtPlanId])
  @@index([accountId])
  @@index([userId])
}

// ==================== LIABILITY PAYMENT AUDIT ====================

model LiabilityPaymentAudit {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Source account snapshot
  sourceAccountId     String
  sourceBalanceBefore Float
  sourceBalanceAfter  Float

  // Target account snapshot
  targetAccountId     String
  targetBalanceBefore Float
  targetBalanceAfter  Float

  // Payment details
  paymentAmount Float
  currency      String
  exchangeRate  Float

  // Audit metadata
  executedBy         String
  executedAt         DateTime @default(now())
  ipAddress          String?
  ipAddressEncrypted String?  @db.Text // Encrypted IP address
  userAgent          String?
  userAgentEncrypted String?  @db.Text // Encrypted user agent

  // Rollback information
  isRolledBack   Boolean   @default(false)
  rolledBackAt   DateTime?
  rollbackReason String?

  @@index([transactionId])
  @@index([executedBy])
  @@index([executedAt])
}

// ==================== BUDGETING ====================

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetScope {
  CATEGORIES
  LEGACY_GLOBAL
}

model BudgetCategory {
  budgetId   String
  categoryId String

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([budgetId, categoryId])
  @@index([budgetId])
  @@index([categoryId])
}

model Budget {
  id        String       @id @default(cuid())
  name      String
  amount    Float
  period    BudgetPeriod
  scope     BudgetScope  @default(CATEGORIES)
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean      @default(true)

  categories BudgetCategory[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== SAVINGS GOALS ====================

model SavingsGoalAccount {
  goalId    String
  accountId String

  goal    SavingsGoal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([goalId, accountId])
  @@index([goalId])
  @@index([accountId])
}

model SavingsGoal {
  id                   String    @id @default(cuid())
  name                 String
  nameEncrypted        String?   @db.Text // Encrypted name
  targetAmount         Float
  targetDate           DateTime?
  icon                 String? // emoji or icon name
  color                String? // hex color for UI
  description          String?
  descriptionEncrypted String?   @db.Text // Encrypted description

  // Progress is derived from linked account balances (not stored)
  accounts SavingsGoalAccount[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== PERSONAL ASSETS ====================

enum PersonalAssetCategory {
  ELECTRONICS
  VEHICLE
  PROPERTY
  FURNITURE
  JEWELRY
  COLLECTIBLE
  EQUIPMENT
  OTHER
}

model PersonalAsset {
  id                   String                @id @default(cuid())
  name                 String
  nameEncrypted        String?               @db.Text
  category             PersonalAssetCategory
  currentValue         Float
  currency             String                @default("IDR")
  currentValuedAt      DateTime
  purchaseDate         DateTime?
  purchasePrice        Float?
  purchaseCurrency     String?
  notes                String?
  notesEncrypted       String?               @db.Text
  disposedAt           DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  valuations PersonalAssetValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, disposedAt])
  @@index([userId, category])
}

model PersonalAssetValuation {
  id       String   @id @default(cuid())
  value    Float
  currency String   @default("IDR")
  valuedAt DateTime

  assetId String
  asset   PersonalAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([assetId, valuedAt])
  @@index([userId])
}

enum NotificationType {
  TEST
  SUBSCRIPTION_RENEWAL
  RECURRING_TRANSACTION_DUE
  BUDGET_THRESHOLD
  LOW_CASH_FORECAST
  MONTHLY_NET_WORTH_SNAPSHOT
  GOAL_PROGRESS
  IMPORT_EXPORT_COMPLETION
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  PARTIAL_FAILURE
  FAILED
  SKIPPED
}

model PushSubscription {
  id                 String   @id @default(cuid())
  endpointHash       String   @unique
  endpointEncrypted  String   @db.Text
  p256dhEncrypted    String   @db.Text
  authEncrypted      String   @db.Text
  userAgentEncrypted String?  @db.Text
  expirationTime     DateTime?
  lastSeenAt         DateTime @default(now())
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  failureCount       Int      @default(0)
  disabledAt         DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, disabledAt])
  @@index([expirationTime])
  @@index([lastFailureAt])
}

model NotificationPreference {
  id                           String  @id @default(cuid())
  pushEnabled                  Boolean @default(false)
  subscriptionRenewalEnabled   Boolean @default(true)
  recurringTransactionEnabled  Boolean @default(true)
  budgetThresholdEnabled       Boolean @default(true)
  lowCashForecastEnabled       Boolean @default(true)
  monthlySnapshotEnabled       Boolean @default(true)
  goalProgressEnabled          Boolean @default(true)
  importExportCompletionEnabled Boolean @default(false)
  subscriptionReminderLeadDays Int     @default(3)
  recurringReminderLeadDays    Int     @default(1)
  budgetThresholdPercent       Int     @default(80)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationEvent {
  id           String                     @id @default(cuid())
  type         NotificationType
  dedupeKey    String
  title        String
  body         String
  targetPath   String
  status       NotificationDeliveryStatus @default(PENDING)
  successCount Int                        @default(0)
  failureCount Int                        @default(0)
  skippedReason String?
  metadataJson Json?
  sentAt       DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type, dedupeKey])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}
