// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

// ==================== AUTH.JS MODELS ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  mainCurrency  String    @default("IDR") // User's preferred currency for reporting

  // Financial targets
  retirementTarget Float?
  monthlyBudget    Float?

  // Encryption metadata for field-level encryption
  encryptionSalt    String? @db.Text // Base64-encoded salt for key derivation
  encryptionVersion Int     @default(1) // For key rotation support

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js relations
  accounts AuthAccount[]
  sessions Session[]

  // Financial relations
  financialAccounts FinancialAccount[]
  transactions      Transaction[]
  categories        Category[]
  investmentAssets  InvestmentAsset[]
  tradeHistory      TradeHistory[]
  recurringRules    RecurringRule[]
  budgets           Budget[]
  savingsGoals      SavingsGoal[]
  personalAssets    PersonalAsset[]
  personalAssetValuations PersonalAssetValuation[]
}

model AuthAccount {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ==================== FINANCIAL MODELS ====================

enum AccountType {
  BANK
  CASH
  INVESTMENT
  LOAN
  CREDIT_CARD
  LOAN_RECEIVABLE
}

model FinancialAccount {
  id                   String      @id @default(cuid())
  name                 String
  nameEncrypted        String?     @db.Text // Encrypted account name
  type                 AccountType
  currency             String      @default("IDR") // ISO currency code
  balance              Float       @default(0)
  description          String?
  descriptionEncrypted String?     @db.Text // Encrypted description
  isActive             Boolean     @default(true)

  // Encryption metadata
  lastEncryptedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromTransactions Transaction[] @relation("FromAccount")
  toTransactions   Transaction[] @relation("ToAccount")

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  investmentAssets InvestmentAsset[]
  tradeHistories   TradeHistory[]
  transactions     Transaction[]
  savingsGoals     SavingsGoal[]

  @@index([userId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  LIABILITY_PAYMENT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

model Category {
  id       String          @id @default(cuid())
  name     String
  icon     String?
  color    String?
  type     TransactionType
  isSystem Boolean         @default(false) // Seed/default marker for starter categories

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id                   String          @id @default(cuid())
  amount               Float
  currency             String          @default("IDR") // Transaction currency
  exchangeRate         Float           @default(1) // Rate to convert to user's main currency
  type                 TransactionType
  description          String?
  descriptionEncrypted String?         @db.Text // Encrypted description
  location             String?         @db.Text
  latitude             Float?
  longitude            Float?
  googleMapsLink       String?         @db.Text
  date                 DateTime        @default(now())
  isRecurring          Boolean         @default(false)

  // Liability payment specific fields
  referenceNumber          String?       @unique
  referenceNumberEncrypted String?       @db.Text // Encrypted reference number
  isOverpayment            Boolean       @default(false)
  paymentStatus            PaymentStatus @default(COMPLETED)

  // Audit trail fields
  createdBy          String?
  createdByEncrypted String?  @db.Text // Encrypted createdBy
  processedAt        DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String
  account   FinancialAccount @relation("FromAccount", fields: [accountId], references: [id], onDelete: Cascade)

  toAccountId String?
  toAccount   FinancialAccount? @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  financialAccountId String?

  // Reverse relation for audit
  liabilityPaymentAudit LiabilityPaymentAudit?

  @@index([userId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@index([date])
  @@index([referenceNumber])
  @@index([financialAccountId], map: "Transaction_financialAccountId_fkey")
  @@index([recurringRuleId], map: "Transaction_recurringRuleId_fkey")
}

// ==================== INVESTMENT MODELS ====================

model InvestmentAsset {
  id          String   @id @default(cuid())
  symbol      String // e.g., AAPL, BTC-USD
  name        String? // e.g., Apple Inc.
  quantity    Float
  avgBuyPrice Float // Cost basis per unit
  currency    String   @default("IDR") // Asset's trading currency
  unitType    UnitType @default(UNIT) // Unit of quantity

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Account linkage for tracking which investment account holds this asset
  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  tradeHistory TradeHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
  @@index([accountId])
}

enum TradeType {
  BUY
  SELL
}

enum UnitType {
  UNIT // Stocks, ETFs - 1 share = 1 unit
  TROY_OUNCE // Precious metals from Yahoo Finance
  GRAM // User preference for metals
}

model TradeHistory {
  id             String    @id @default(cuid())
  type           TradeType
  quantity       Float
  pricePerUnit   Float
  totalAmount    Float
  fees           Float     @default(0)
  date           DateTime  @default(now())
  notes          String?
  notesEncrypted String?   @db.Text // Encrypted trade notes
  unitType       UnitType  @default(UNIT)

  // Realized PnL (only for SELL trades)
  realizedPnL Float?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assetId String
  asset   InvestmentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Account linkage for audit trail - tracks which account was debited/credited
  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  // Audit trail fields for balance tracking
  balanceBefore Float? // Account balance before this transaction
  balanceAfter  Float? // Account balance after this transaction

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assetId])
  @@index([accountId])
  @@index([date])
}

// ==================== RECURRING TRANSACTIONS ====================

enum RecurringInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringRule {
  id            String            @id @default(cuid())
  name          String
  nameEncrypted String?           @db.Text // Encrypted name
  amount        Float
  currency      String            @default("IDR")
  type          TransactionType
  interval      RecurringInterval
  nextDueDate   DateTime
  endDate       DateTime?
  isActive      Boolean           @default(true)

  // Template data for creating transactions
  description          String?
  descriptionEncrypted String? @db.Text // Encrypted description
  categoryId           String?
  accountId            String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([nextDueDate])
}

// ==================== EXCHANGE RATES CACHE ====================

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  fetchedAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency])
  @@index([fetchedAt])
}

// ==================== LIABILITY PAYMENT AUDIT ====================

model LiabilityPaymentAudit {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Source account snapshot
  sourceAccountId     String
  sourceBalanceBefore Float
  sourceBalanceAfter  Float

  // Target account snapshot
  targetAccountId     String
  targetBalanceBefore Float
  targetBalanceAfter  Float

  // Payment details
  paymentAmount Float
  currency      String
  exchangeRate  Float

  // Audit metadata
  executedBy         String
  executedAt         DateTime @default(now())
  ipAddress          String?
  ipAddressEncrypted String?  @db.Text // Encrypted IP address
  userAgent          String?
  userAgentEncrypted String?  @db.Text // Encrypted user agent

  // Rollback information
  isRolledBack   Boolean   @default(false)
  rolledBackAt   DateTime?
  rollbackReason String?

  @@index([transactionId])
  @@index([executedBy])
  @@index([executedAt])
}

// ==================== BUDGETING ====================

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Budget {
  id        String       @id @default(cuid())
  name      String
  amount    Float
  period    BudgetPeriod
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean      @default(true)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
}

// ==================== SAVINGS GOALS ====================

model SavingsGoal {
  id                   String    @id @default(cuid())
  name                 String
  nameEncrypted        String?   @db.Text // Encrypted name
  targetAmount         Float
  currentAmount        Float     @default(0)
  targetDate           DateTime?
  icon                 String? // emoji or icon name
  color                String? // hex color for UI
  description          String?
  descriptionEncrypted String?   @db.Text // Encrypted description
  isCompleted          Boolean   @default(false)

  // Optional: Link to account for auto-tracking
  accountId String?
  account   FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
}

// ==================== PERSONAL ASSETS ====================

enum PersonalAssetCategory {
  ELECTRONICS
  VEHICLE
  PROPERTY
  FURNITURE
  JEWELRY
  COLLECTIBLE
  EQUIPMENT
  OTHER
}

model PersonalAsset {
  id                   String                @id @default(cuid())
  name                 String
  nameEncrypted        String?               @db.Text
  category             PersonalAssetCategory
  currentValue         Float
  currency             String                @default("IDR")
  currentValuedAt      DateTime
  purchaseDate         DateTime?
  purchasePrice        Float?
  purchaseCurrency     String?
  notes                String?
  notesEncrypted       String?               @db.Text
  disposedAt           DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  valuations PersonalAssetValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, disposedAt])
  @@index([userId, category])
}

model PersonalAssetValuation {
  id       String   @id @default(cuid())
  value    Float
  currency String   @default("IDR")
  valuedAt DateTime

  assetId String
  asset   PersonalAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([assetId, valuedAt])
  @@index([userId])
}
